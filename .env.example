# Redshift Data API
CLUSTER_ID=data-warehouse-xxxx
DATABASE=xxxxx
SECRET_ARN=arn:aws:secretsmanager:us-east-1:xxxxx:secret:xxxx/connections-xxxx
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=uzsts

# Logging
LOG_LEVEL=INFO

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

DATA_API_POLL_INTERVAL_SEC=0.1