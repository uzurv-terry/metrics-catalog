# Redshift Data API
CLUSTER_ID=data-warehouse-uat-cluster
DATABASE=uzurv_app_rs
SECRET_ARN=arn:aws:secretsmanager:us-east-1:371707344195:secret:datawarehouse-uat/connections-8h7s3n
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=uzsts

# Logging
LOG_LEVEL=INFO

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

DATA_API_POLL_INTERVAL_SEC=0.1

# AWS credentials are intentionally not set here.
# Use AWS_PROFILE=uzsts and ensure AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY
# are NOT exported in your shell when running the app.

# python3 -m src.app


### Example AWS CLI commands for testing
# aws secretsmanager describe-secret \
#   --secret-id datawarehouse-uat/connections \
#   --profile uzsts \
#   --region us-east-1


